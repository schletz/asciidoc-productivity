{
  "name": "asciidoc-productivity",
  "publisher": "schletz",
  "displayName": "asciidoc-productivity",
  "description": "Improves AsciiDoc editing features.",
  "version": "1.0.21",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/schletz/asciidoc-productivity"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "AsciiDoc Productivity",
      "properties": {
        "asciidoc-productivity.includeExtensions": {
          "type": "string",
          "default": "abap|actionscript|ada|adb|ado|adoc|ads|apache|apex|apib|applescript|as|asm|aug|awk|b|bat|bbc|bf|bib|bicep|biml|bpf|brs|bsl|c|cc|ceylon|cfc|cfm|cjs|clj|cljc|cljs|cls|cmake|cmd|cmm|coffee|conf|coq|cpp|cr|cs|csproj|css|csvs|cu|cxx|cyp|cypher|d|dart|dfy|diff|dig|do|dockerfile|dot|e|ecl|edp|eex|elm|eml|epp|erb|erl|ex|exs|f|f90|factor|feature|frag|fs|fsi|fsx|gd|glsl|go|gql|gradle|graphql|groovy|gv|h|hack|haml|hbs|hcl|hcr|hh|hlsl|hocon|hpp|hql|hrl|hs|htm|html|http|hx|hy|ice|idl|idr|ijs|ini|io|ipf|irb|isbl|j2|janet|java|jinja|jl|js|jsl|json|json5|jsonnet|jsp|jsx|kt|kts|lasso|lean|lhs|liquid|lisp|litcoffee|ll|ls|lsp|lua|lus|lut|m|magik|mak|matlab|md|meson|mjs|mk|ml|mli|mm|mojo|moon|mos|mxml|mzn|ndf|nginx|nim|nix|ocl|os|p|p4|pas|patch|php|phtml|pkb|pks|pl|plist|pm|pony|pp|praat|pro|prolog|properties|proto|ps|ps1|psm1|puml|py|pyw|pyx|q|qml|r|rb|re|rego|rei|res|resi|rkt|rml|robot|rq|rs|s|sas|sass|sc|scala|scm|scpt|scss|sed|service|sh|sieve|slim|sml|sqf|sql|ss|ssh|st|stan|sv|svelte|swift|syz|tap|tcl|tex|tf|thy|tlp|toml|tpl|trigger|ts|tsx|ttcn3|ttl|twig|txt|v|vala|vb|vcl|vert|veryl|vhd|vhdl|vim|vm|vue|wlk|xml|xojo_code|xpath|xq|xquery|yaml|yang|yml|zig",
          "description": "Regex for file extensions that should be considered when copying (e.g., 'cs|csproj|ts|html')."
        },
        "asciidoc-productivity.excludeDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "bin",
            "obj",
            "node_modules"
          ],
          "description": "Directories that should be ignored when copying."
        },
        "asciidoc-productivity.excludeFiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "package-lock.json"
          ],
          "description": "Files that should be ignored when copying."
        },
        "asciidoc-productivity.completionsUrl": {
          "type": "string",
          "default": "http://localhost:1234/v1/chat/completions",
          "description": "OpenAI compatible LLM server."
        },
        "asciidoc-productivity.llm": {
          "type": "string",
          "default": "lmstudio-community/Qwen3.6-35B-A3B-GGUF",
          "description": "LLM to be used."
        },
        "asciidoc-productivity.maxOutputTokens": {
          "type": "number",
          "default": 4096,
          "description": "Maximum token count of the response."
        },
        "asciidoc-productivity.getDefaultTargetLanguage": {
          "type": "string",
          "default": "en-US",
          "description": "Default target language for translations."
        },
        "asciidoc-productivity.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for cloud providers (leave empty for local models like LM Studio)."
        },
        "asciidoc-productivity.systemPrompts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Name of the command shown in the dropdown menu."
              },
              "prompt": {
                "type": "string",
                "description": "The system prompt sent to the LLM."
              }
            }
          },
          "default": [
            {
              "name": "Check spelling and grammar",
              "prompt": "You are an expert editor for asciidoc documents. Correct spelling, grammar, and punctuation of the provided text.\nMaintain the original tone and all formatting (especially AsciiDoc syntax and source blocks).\nOutput ONLY the corrected text. Do not add explanations or comments."
            },
            {
              "name": "Simplify text",
              "prompt": "You are an expert editor for asciidoc documents. Rewrite the provided German text to be clear and easily understandable for non-native students with a B2 language level.\nKeep all technical terms intact, but resolve overly nested sentences (Schachtelsätze) and avoid unnecessary passive voice.\nMaintain the original tone and all formatting (especially AsciiDoc syntax and source blocks).\nOutput ONLY the rewritten text. Do not add explanations or comments."
            }
          ],
          "description": "List of system prompts available for the 'Send to AI' command."
        }
      }
    },
    "commands": [
      {
        "command": "asciidoc-productivity.insertSourceBlock",
        "title": "Insert clipboard as source block"
      },
      {
        "command": "asciidoc-productivity.insertImageBlock",
        "title": "Insert image from URL"
      },
      {
        "command": "asciidoc-productivity.insertTsvTable",
        "title": "Insert clipboard as table"
      },
      {
        "command": "asciidoc-productivity.insertImageFromFile",
        "title": "Insert image from file"
      },
      {
        "command": "asciidoc-productivity.insertImageFromClipboard",
        "title": "Insert image from clipboard"
      },
      {
        "command": "asciidoc-productivity.insertFileAsSourceBlock",
        "title": "Insert file as source block"
      },
      {
        "command": "asciidoc-productivity.copySourcesToClipboard",
        "title": "Copy sources to clipboard",
        "icon": "$(notebook-open-as-text)"
      },
      {
        "command": "asciidoc-productivity.copyAsTsv",
        "title": "Copy AsciiDoc Table as TSV to clipboard"
      },
      {
        "command": "asciidoc-productivity.translate",
        "title": "LLM: Translate"
      },
      {
        "command": "asciidoc-productivity.sendToAi",
        "title": "LLM: Send to AI..."
      },
      {
        "command": "asciidoc-productivity.sendFilesToAi",
        "title": "LLM: Send File(s) to AI..."
      },
      {
        "command": "asciidoc-productivity.exportAsPdf",
        "title": "Export as PDF (requires docker)"
      },
      {
        "command": "asciidoc-productivity.showPreview",
        "title": "Open AsciiDoc Preview",
        "icon": {
          "light": "./media/preview-branded-light.svg",
          "dark": "./media/preview-branded-dark.svg"
        }
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "asciidoc-productivity.copySourcesToClipboard",
          "when": "view == workbench.explorer.fileView",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "asciidoc-productivity.insertSourceBlock",
          "when": "editorLangId == asciidoc",
          "group": "navigation@1"
        },
        {
          "command": "asciidoc-productivity.insertTsvTable",
          "when": "editorLangId == asciidoc",
          "group": "navigation@2"
        },
        {
          "command": "asciidoc-productivity.insertImageBlock",
          "when": "editorLangId == asciidoc",
          "group": "navigation@3"
        },
        {
          "command": "asciidoc-productivity.insertImageFromFile",
          "when": "editorLangId == asciidoc",
          "group": "navigation@4"
        },
        {
          "command": "asciidoc-productivity.insertImageFromClipboard",
          "when": "editorLangId == asciidoc",
          "group": "navigation@5"
        },
        {
          "command": "asciidoc-productivity.copyAsTsv",
          "when": "editorLangId == asciidoc",
          "group": "navigation@6"
        },
        {
          "command": "asciidoc-productivity.translate",
          "when": "editorHasSelection",
          "group": "navigation@7"
        },
        {
          "command": "asciidoc-productivity.sendToAi",
          "when": "editorHasSelection",
          "group": "navigation@8"
        }
      ],
      "editor/title": [
        {
          "command": "asciidoc-productivity.showPreview",
          "when": "editorLangId == asciidoc",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "asciidoc-productivity.insertFileAsSourceBlock",
          "group": "navigation"
        },
        {
          "command": "asciidoc-productivity.exportAsPdf",
          "when": "resourceExtname == .adoc",
          "group": "navigation"
        },
        {
          "command": "asciidoc-productivity.sendFilesToAi",
          "group": "navigation"
        },
        {
          "command": "asciidoc-productivity.copySourcesToClipboard",
          "group": "2_workspace"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/tar-stream": "^3.1.4",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "dockerode": "^4.0.10",
    "mammoth": "^1.12.0",
    "pdfreader": "^3.0.8",
    "tar-stream": "^3.1.8"
  }
}